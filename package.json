{
  "name": "sqltabs",
  "version": "1.3.4",
  "author": "Sednai Sàrl <sqltabs@sedn.ai>",
  "description": "SQL Tabs - a browser for databases",
  "repository": {
    "type": "git",
    "url": "https://github.com/sasha-alias/sqltabs"
  },
  "license": "GPL-3.0",
  "main": "main.js",
  "window": {
    "toolbar": false
  },
  "build": {
    "appId": "com.sqltabs",
    "productName": "SQL Tabs",
    "directories": {
      "buildResources": "build-resources",
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "logo.png",
      "logo.ico",
      "css",
      "fonts",
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "category": "Development",
      "maintainer": "Sednai <noreply@sedn.ai>",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "win": {
      "icon": "logo.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "alasql": "^0.3.9",
    "async": "^1.4.2",
    "bootstrap": "^3.3.2",
    "brace": "^0.11.1",
    "c3": "^0.4.0",
    "crypto-js": "^3.1.9-1",
    "electron-updater": "^6.3.9",
    "flux": "2.0.1",
    "jquery": "^3.3.1",
    "lowdb": "0.7.2",
    "marked": "^0.3.3",
    "microevent": "1.0.0",
    "performance-now": "^0.2.0",
    "pg": "^8.13.1",
    "pg-connection-string": "^2.7.0",
    "react": "^0.14.9",
    "react-bootstrap": "^0.30.10",
    "react-color": "^2.11.4",
    "react-dom": "^0.14.9",
    "request": "^2.60.0",
    "sql-formatter": "^1.2.1",
    "tunnel-ssh": "^4.1.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-react-jsx": "^7.23.0",
    "electron": "^31.7.0",
    "electron-builder": "^26.0.0",
    "electron-reload": "^1.5.0"
  },
  "scripts": {
    "postinstall": "babel --plugins @babel/plugin-transform-react-jsx --out-dir=build src/",
    "start": "electron ./ --dev",
    "compile": "babel --plugins @babel/plugin-transform-react-jsx --out-dir=build src/",
    "compile:watch": "babel --plugins @babel/plugin-transform-react-jsx --out-dir=build src/ --watch",
    "build": "npm run compile",
    "dist:linux": "npm run compile && electron-builder --linux --publish never",
    "dist:mac": "npm run compile && electron-builder --mac --publish never",
    "dist:win": "npm run compile && electron-builder --win --publish never"
  }
}
